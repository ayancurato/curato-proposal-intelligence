# Groq API
GROQ_API_KEY=your_api_key

# Database
DATABASE_URL=sqlite+aiosqlite:///./curato.db

# Upload configuration
UPLOAD_DIR=../uploads
MAX_FILE_SIZE_MB=25
MAX_PROPOSALS_PER_SESSION=5

# AI Model
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Server
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
